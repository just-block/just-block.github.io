{
  "name": "just-block-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:dev": "tsc && vite build --mode development",
    "build:prod": "tsc && vite build",
    "build:prod:zip": "npm run build:prod && rm -f justBlock.zip && cd dist && zip -r ../justBlock.zip . && open https://chrome.google.com/webstore/devconsole/06336b0b-06ac-4772-9969-db9169ef0463/jbclpnhceoikcflgfdlfonceofcbjpgd/edit/package",
    "prettier:fix": "npx prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "npx vitest src",
    "dev": "vite --mode=development",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "bundle-visualize": "npx vite-bundle-visualizer",
    "typecheck": "npx tsc"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "@supabase/supabase-js": "^2.43.4",
    "@types/uuid": "^9.0.8",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.0",
    "client-captcha": "^0.8.5",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.15",
    "lucide-react": "^0.383.0",
    "mobx": "^6.12.0",
    "mobx-form-lite": "^0.9.4",
    "mobx-persist-store": "^1.1.5",
    "mobx-react-lite": "^4.0.6",
    "mobx-react-observer": "^1.1.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simplebar-react": "^3.2.4",
    "supabase": "^1.110.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/chrome": "^0.0.263",
    "@types/node": "^20.14.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^1.4.0"
  }
}
